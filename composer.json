{
  "name": "bhargavkalambhe/ses-queb-sdk",
  "description": "Official PHP SDK for SES-Queb API - Scaffold secure projects and audit vulnerabilities",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Bhargav Kalambhe",
      "email": "your.email@example.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "guzzlehttp/guzzle": "^7.0",
    "illuminate/support": "^11.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "php-parallel-lint/php-parallel-lint": "^1.3"
  },
  "autoload": {
    "psr-4": {
      "BhargavKalambhe\\SESQuebSDK\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "BhargavKalambhe\\SESQuebSDK\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "keywords": [
    "ses-queb",
    "scaffold",
    "security",
    "audit",
    "vulnerabilities",
    "laravel",
    "api-client"
  ],
  "homepage": "https://github.com/bhargavkalambhe/ses-queb-php-sdk"
}
